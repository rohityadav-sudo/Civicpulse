{
  "expo": {
    "name": "CivicsPulse",
    "slug": "civicpulse",
    "scheme": "civicpulse",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0E1A",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.civicpulse.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CivicsPulse needs your location to map your issue to the correct ward and representative.",
        "NSMicrophoneUsageDescription": "CivicsPulse needs microphone access for voice issue submission.",
        "NSCameraUsageDescription": "CivicsPulse needs camera access to photograph civic issues.",
        "NSPhotoLibraryUsageDescription": "CivicsPulse needs photo library access to attach evidence to issues."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.civicpulse.app",
      "versionCode": 4,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e278029a-c1e3-4a27-988a-55ba74d1dfa4"
      }
    },
    "owner": "rohity008"
  }
}
